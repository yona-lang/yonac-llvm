GENFN_BEGIN yona_Std_IO__stderrFd stderrFd
stderrFd = 2
GENFN_END
GENFN_BEGIN yona_Std_IO__eprint eprint
eprint s = yona_Std_IO__writeStr stderrFd s
GENFN_END
GENFN_BEGIN yona_Std_IO__readLine readLine
readLine = yona_Std_IO__readLineFd stdinFd
GENFN_END
GENFN_BEGIN yona_Std_IO__stdinFd stdinFd
stdinFd  = 0
GENFN_END
GENFN_BEGIN yona_Std_IO__stdoutFd stdoutFd
stdoutFd = 1
GENFN_END
GENFN_BEGIN yona_Std_IO__print print
print s = yona_Std_IO__writeStr stdoutFd s
GENFN_END
GENFN_BEGIN yona_Std_IO__println println
println s = yona_Std_IO__writeLine stdoutFd s
GENFN_END
GENFN_BEGIN yona_Std_IO__eprintln eprintln
eprintln s = yona_Std_IO__writeLine stderrFd s
GENFN_END
GENFN_BEGIN yona_Std_IO__putStr putStr
putStr fd s = yona_Std_IO__writeStr fd s
GENFN_END
GENFN_BEGIN yona_Std_IO__putStrLn putStrLn
putStrLn fd s = yona_Std_IO__writeLine fd s
GENFN_END
GENFN_BEGIN yona_Std_IO__isTty isTty
isTty fd = yona_Std_IO__isTty fd
GENFN_END
GENFN_BEGIN yona_Std_IO__write write
write fd s = yona_Std_IO__writeStr fd s
GENFN_END
GENFN_BEGIN yona_Std_IO__readLineFrom readLineFrom
readLineFrom fd = yona_Std_IO__readLineFd fd
GENFN_END
GENFN_BEGIN yona_Std_IO__isatty isatty
isatty fd = yona_Std_IO__isTty fd
GENFN_END
GENFN_BEGIN yona_Std_IO__flush flush
flush fd = yona_Std_IO__flushFd fd
GENFN_END
