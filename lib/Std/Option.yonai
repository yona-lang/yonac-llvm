GENFN_BEGIN yona_Std_Option__toResult toResult
toResult err opt =
    case opt of
        Some value -> (:ok, value)
        None       -> (:err, err)
    end
GENFN_END
GENFN_BEGIN yona_Std_Option__isSome isSome
isSome opt =
    case opt of
        Some _ -> true
        None   -> false
    end
GENFN_END
GENFN_BEGIN yona_Std_Option__orElse orElse
orElse alternative opt =
    case opt of
        Some value -> Some value
        None       -> alternative
    end
GENFN_END
GENFN_BEGIN yona_Std_Option__unwrapOr unwrapOr
unwrapOr default opt =
    case opt of
        Some value -> value
        None       -> default
    end
GENFN_END
GENFN_BEGIN yona_Std_Option__filter filter
filter pred opt =
    case opt of
        Some value -> if pred value then Some value else None
        None       -> None
    end
GENFN_END
GENFN_BEGIN yona_Std_Option__isNone isNone
isNone opt =
    case opt of
        None   -> true
        Some _ -> false
    end
GENFN_END
GENFN_BEGIN yona_Std_Option__map map
map fn opt =
    case opt of
        Some value -> Some (fn value)
        None       -> None
    end
GENFN_END
GENFN_BEGIN yona_Std_Option__flatMap flatMap
flatMap fn opt =
    case opt of
        Some value -> fn value
        None       -> None
    end
GENFN_END
GENFN_BEGIN yona_Std_Option__zip zip
zip optA optB =
    case optA of
        Some a -> case optB of
            Some b -> Some (a, b)
            None   -> None
        end
        None -> None
    end
GENFN_END
GENFN_BEGIN yona_Std_Option__fold fold
fold onNone onSome opt =
    case opt of
        Some value -> onSome value
        None       -> onNone
    end
GENFN_END
