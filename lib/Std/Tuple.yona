module Std\Tuple

export fst, snd, swap, mapBoth, mapFst, mapSnd, toList, curry, uncurry

fst (a, _) = a

snd (_, b) = b

swap (a, b) = (b, a)

mapBoth f g (a, b) = (f a, g b)

mapFst f (a, b) = (f a, b)

mapSnd f (a, b) = (a, f b)

toList (a, b) = [a, b]

curry f a b = f (a, b)

uncurry f (a, b) = f a b
