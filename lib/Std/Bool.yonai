GENFN_BEGIN yona_Std_Bool__implies implies
implies a b = if a then b else true
GENFN_END
GENFN_BEGIN yona_Std_Bool__not not
not x = if x then false else true
GENFN_END
GENFN_BEGIN yona_Std_Bool__xor xor
xor a b = if a then not b else b
GENFN_END
GENFN_BEGIN yona_Std_Bool__and and
and a b = if a then b else false
GENFN_END
GENFN_BEGIN yona_Std_Bool__or or
or a b = if a then true else b
GENFN_END
GENFN_BEGIN yona_Std_Bool__when when
when cond fn = if cond then fn () else :ok
GENFN_END
GENFN_BEGIN yona_Std_Bool__unless unless
unless cond fn = if cond then :ok else fn ()
GENFN_END
