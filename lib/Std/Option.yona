module Std\Option exports Some, None, isSome, isNone, unwrapOr, map as

type Option a = Some a | None

isSome opt =
    case opt of
        Some _ -> true
        None   -> false
    end

isNone opt =
    case opt of
        None   -> true
        Some _ -> false
    end

unwrapOr default opt =
    case opt of
        Some value -> value
        None       -> default
    end

map fn opt =
    case opt of
        Some value -> Some (fn value)
        None       -> None
    end

end
