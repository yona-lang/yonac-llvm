module Std\Test

export assertEqual, assertTrue, assertFalse

assertEqual expected actual =
    if expected == actual then (:pass, "assertEqual")
    else (:fail, "assertEqual: expected equal values")

assertTrue value =
    if value then (:pass, "assertTrue")
    else (:fail, "assertTrue: expected true")

assertFalse value =
    if value then (:fail, "assertFalse: expected false")
    else (:pass, "assertFalse")
