let abs x = if x < 0 then 0 - x else x in
let safe queen qs col = case qs of
    [] -> true
    [q | rest] -> if queen == q then false
                  else if abs (queen - q) == col then false
                  else safe queen rest (col + 1)
end in
let solve n row placed =
    if row > n then 1
    else let tryCol col =
        if col > n then 0
        else
            let withCol = if safe col placed 1 then solve n (row + 1) (col :: placed) else 0 in
            let skipCol = tryCol (col + 1) in
            withCol + skipCol
    in tryCol 1
in solve 7 1 []
