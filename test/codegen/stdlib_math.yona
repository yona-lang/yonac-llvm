let abs = \x -> if x < 0 then 0 - x else x in let gcd = \a b -> let a2 = abs a in let b2 = abs b in if b2 == 0 then a2 else gcd b2 (a2 % b2) in let pow = \base exp -> if exp <= 0 then 1 else base * (pow base (exp - 1)) in let factorial = \n -> if n <= 1 then 1 else n * (factorial (n - 1)) in (pow 2 10) + (gcd 12 8) + (factorial 5) + (abs (0 - 7))
