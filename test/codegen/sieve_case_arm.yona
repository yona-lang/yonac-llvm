let sieve n =
    let filterMultiples p seq = case seq of [] -> []; [h|t] -> if h % p == 0 then filterMultiples p t else h :: (filterMultiples p t) end in
    let go candidates = case candidates of [] -> []; [p|rest] -> p :: (go (filterMultiples p rest)) end in
    let range start stop = if start > stop then [] else start :: (range (start + 1) stop) in
    let primes = go (range 2 n) in
    case primes of [] -> 0; _ -> let len seq = case seq of [] -> 0; [_|t] -> 1 + (len t) end in len primes end
in sieve 100
