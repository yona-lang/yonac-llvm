import openFile, readBytes, writeBytes, closeFileHandle from Std\File, fromString, length from Std\Bytes in
let wh = openFile "/tmp/yona_binary_test.bin" "w" in
let _ = writeBytes wh (fromString "hello binary") in
let _ = closeFileHandle wh in
let rh = openFile "/tmp/yona_binary_test.bin" "r" in
let data = readBytes rh 12 in
let _ = closeFileHandle rh in
length data
