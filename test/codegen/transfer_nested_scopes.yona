let sumAll xs = case xs of [] -> 0; [h|t] -> h + (sumAll t) end in
let go mode xs ys =
    if mode == 1 then
        case xs of
            [] -> sumAll ys
            [h|_] -> h + (sumAll ys)
        end
    else
        sumAll xs
in
(go 1 [] [10, 20, 30], go 1 [100, 200] [1, 2], go 0 [5, 5, 5] [])
