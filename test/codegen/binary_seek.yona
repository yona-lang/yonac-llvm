import openFile, readBytes, writeBytes, seek, closeFileHandle from Std\File, fromString, get from Std\Bytes in
let wh = openFile "/tmp/yona_binary_seek.bin" "w" in
let _ = writeBytes wh (fromString "abcdefghij") in
let _ = closeFileHandle wh in
let rh = openFile "/tmp/yona_binary_seek.bin" "r" in
let _ = seek rh 5 "set" in
let data = readBytes rh 3 in
let _ = closeFileHandle rh in
get data 0
