#pragma once
// Generated by CMake — absolute path to the repository root (same as CMAKE_SOURCE_DIR).
#define YONA_SOURCE_DIR "@CMAKE_SOURCE_DIR@"

/* MSVC/UCRT tests use _popen/_pclose; map POSIX names for portable test sources. */
#if defined(_WIN32)
#include <stdio.h>
#ifndef popen
#define popen _popen
#endif
#ifndef pclose
#define pclose _pclose
#endif
#endif
